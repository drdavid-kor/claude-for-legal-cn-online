{
  "name": "claude-for-legal-cn-online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BYOK online guided-chat tool for China-localized legal skills.",
  "scripts": {
    "generate:contexts": "node scripts/generate-contexts.mjs",
    "predev": "npm run generate:contexts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --config ./wrangler.toml --assets ./public src/worker.ts",
    "test": "node test/run-tests.mjs",
    "check": "node test/run-tests.mjs",
    "pretest": "npm run generate:contexts",
    "precheck": "npm run generate:contexts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
